APP_ENV=local
DATABASE_URL=postgresql://user:password@host:5432/respace
REDIS_URL=redis://localhost:6379/0

FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Layout generation execution: inline | celery | disabled.
# Leave blank to auto-pick (inline locally, celery otherwise).
GENERATION_EXECUTION_MODE=inline

# Use a real Google AI Studio API key (starts with "AIza..."). An OAuth access
# token will NOT work and generation will fail with an auth error.
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_IMAGE_FALLBACK_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_LEGACY_MODEL=gemini-2.5-flash-image

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=respace-media
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
